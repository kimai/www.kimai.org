---
layout: none
sitemap: false
permalink: /security.xml
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0"
     xmlns:content="http://purl.org/rss/1.0/modules/content/"
     xmlns:wfw="http://wellformedweb.org/CommentAPI/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:atom="http://www.w3.org/2005/Atom"
     xmlns:sy="http://purl.org/rss/1.0/modules/syndication/"
     xmlns:slash="http://purl.org/rss/1.0/modules/slash/"
>
    <channel>
        <title xml:lang="en">Kimai Security Advisories</title>
        <atom:link type="application/atom+xml" href="{% link security.xml %}" rel="self"/>
        <link>https://www.kimai.org/</link>
        <pubDate>{{ site.time | date_to_rfc822 }}</pubDate>
        <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
        <language>en</language>
        <description>Security advisories for Kimai Time-Tracker</description>
        <image>
            <description>Kimai Logo</description>
            <url>{% link images/apple-touch-icon.png %}</url>
            <title>Kimai</title>
            <link>https://www.kimai.org/</link>
            <width>184</width>
            <height>184</height>
        </image>
        {% for post in site.security limit: 10 %}
        <item>
            <title>{{ post.title | xml_escape}}</title>
            <link>https://www.kimai.org{{ post.url }}</link>
            <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
            <guid isPermaLink="true">https://www.kimai.org{{ post.url }}</guid>
            <description>
                <![CDATA[
                        <a href="https://www.kimai.org{{ post.url }}">Read the full advisory here</a>
                    ]]>
            </description>
        </item>
        {% endfor %}
    </channel>
</rss>
